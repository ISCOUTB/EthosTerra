# ============================================================
# .env.example — Plantilla de variables de entorno
# Copiar como .env y completar con los valores del entorno
# ============================================================

# --- Rutas del simulador Java ---
WPS_JAR_PATH=/app/wps-simulator.jar
WPS_LOGS_PATH=/app/src/wps/logs

# --- Node.js ---
NODE_ENV=production

# --- JVM: ajustar según RAM disponible del host ---
# Para VPS con 8 GB: Xmx2g | Con 16 GB: Xmx4g
JAVA_TOOL_OPTIONS=-Xmx2g -Xms512m
