# ============================================================
# .gitignore raíz — WellProdSim monorepo
# ============================================================

# --- Variables de entorno (NUNCA commitear secretos) ---
.env
.env.local
.env.*.local

# --- Archivos de configuración de agentes IA/Copilot ---
# Mantener localmente para desarrollo, NO commitear al repo público
.github/skills/
.github/copilot/
*.instructions.md

# --- Datos de experimentos (generados en tiempo de ejecución) ---
# El directorio data/logs se monta como volumen Docker
data/logs/*.csv
data/logs/*.log
data/experiments_log.txt
# Conservar la estructura del directorio
!data/logs/.gitkeep

# --- Build artifacts Java ---
**/target/
**/build/
*.jar
*.war
*.ear
!**/.mvn/wrapper/maven-wrapper.jar
INFORME.md
experimentos_resultados.md
data/experimentos_resultados.md
data/experiment_results.json

# --- Build artifacts Node.js / Next.js ---
**/node_modules/
**/.next/
**/out/
**/dist/
.npm
.eslintcache

# --- IDEs ---
.idea/
*.iml
*.iws
*.ipr
.vscode/
!.vscode/extensions.json
!.vscode/launch.json

# --- Sistemas operativos ---
.DS_Store
Thumbs.db
desktop.ini

# --- Docker ---
# El override de dev no se commitea si tiene configuraciones locales
docker-compose.override.yml
.docker-build-cache/

# --- Otros ---
temp/
tmp/
*.swp
*.bak
dump.rdb
